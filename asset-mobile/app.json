{
  "expo": {
    "name": "Asset Management",
    "slug": "asset-management-mobile",
    "scheme": [
      "com.assetmanagement.mobile",
      "assetmanagement"
    ],
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.assetmanagement.mobile"
    },
    "android": {
      "package": "com.assetmanagement.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {},
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Asset Management to access your camera to scan QR codes."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Asset Management to access your photos.",
          "cameraPermission": "Allow Asset Management to access your camera to take asset photos."
        }
      ],
      "expo-font",
      "expo-web-browser",
      "@react-native-google-signin/google-signin",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "96496550-ba55-4539-aae8-82c5d9efd421"
      }
    },
    "owner": "jirachotsaonram"
  }
}
